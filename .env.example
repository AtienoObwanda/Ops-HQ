# Ops HQ — copy to .env and fill in your values
# cp .env.example .env

# Name shown in Slack messages and /help (change app name in Slack: Basic Information → Display App Name)
BOT_DISPLAY_NAME=Ops HQ

# From Slack: OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-

# From Slack: Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=

# From Slack: Socket Mode → App-Level Token (scope: connections:write)
SLACK_APP_TOKEN=xapp-

# Where the 9am morning brief is sent — use ONE of these:
# Option A: Your Slack user ID (brief comes to your DMs). Profile → Copy member ID
CS_BRIEF_SLACK_USER_ID=
# Option B: A channel ID (from channel link, the part starting with C...)
# CS_COMMAND_CHANNEL=

# Recon/QA Slack user IDs — get IUT status requests (comma-separated)
# RECON_SLACK_IDS=U0123ABC,U456DEF

# Optional: DB path (default: cs_bot.db). Use OPS_HQ_DB or CS_BOT_DB.
# OPS_HQ_DB=ops_hq.db
# CS_BOT_DB=cs_bot.db

# ── Jira (optional — adds Jira section to morning brief and /brief) ─────────────
# Create API token: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=your@email.com
# JIRA_API_TOKEN=your-api-token
# JIRA_PROJECT_KEYS=NAO,NAD
# JIRA_STALE_HOURS=24
# Only issues created on or after this date (YYYY-MM-DD). Default: 2026-01-01. Set empty to include all.
# JIRA_CREATED_SINCE=2026-01-01
# Jira display name → Slack (format: JiraName:SlackUserID:SlackDisplayName). Get Slack IDs from profile → Copy member ID.
# Your mapping: Felix→Kolakodhek, Joy→Joy, Mark→Kibocha, Mercy→Wairimu, Millicent→Atieno
# JIRA_TO_SLACK=Felix:UxxxFELIX:Kolakodhek,Joy:UxxxJOY:Joy,Mark:UxxxMARK:Kibocha,Mercy:UxxxMERCY:Wairimu,Millicent:UxxxYOU:Atieno

# ── Dashboard (CS Command Center — api.py) ─────────────────────────────────────
# ADMIN_EMAIL=atieno@credrails.com
# ADMIN_PASSWORD=your-secure-password
# COO_EMAIL=coo@credrails.com
# COO_PASSWORD=their-password
# DASHBOARD_PORT=5001
